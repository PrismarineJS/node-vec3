{
  "name": "vec3",
  "version": "0.1.10",
  "description": "3d vector math with good unit tests",
  "main": "./src/mod.js",
  "types": "./src/mod.d.ts",
  "type": "module",
  "scripts": {
    "test": "npm run test-js && npm run test-types",
    "test-js": "mocha --reporter spec",
    "test-types": "tsd",
    "pretest": "npm run lint",
    "lint": "standard",
    "fix": "standard --fix"
  },
  "keywords": [
    "point"
  ],
  "author": "Andrew Kelley",
  "license": "BSD",
  "devDependencies": {
    "mocha": "^11.0.1",
    "standard": "^17.0.0",
    "tsd": "^0.25.0",
    "vec3": "file:../src/mod.js"
  },
  "exports": {
    "require": "./src/mod.cjs"
  },
  "tsd": {
    "directory": "test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PrismarineJS/node-vec3.git"
  }
}
